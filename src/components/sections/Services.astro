---
import { services } from '@/data/services';
import ServiceCard from './ServiceCard.astro';
---
<section id="services" class="max-w-content mx-auto px-6 pt-section pb-8">
  <div class="reveal flex flex-wrap items-end justify-between gap-6 mb-12">
    <div>
      <span class="holo-text uppercase tracking-[.14em] text-[.8rem] font-bold block">Nos services</span>
      <h2 class="text-[clamp(2rem,4.4vw,3.4rem)] mt-[.9rem] max-w-[20ch] tracking-[-.01em]">
        Cinq façons de sublimer votre intérieur
      </h2>
    </div>
    <p class="max-w-[36ch] text-white/60 leading-[1.6]">
      Chaque prestation est réalisée sur-mesure, avec des composants haut de gamme et une finition invisible.
    </p>
  </div>

  <div class="grid grid-cols-[repeat(auto-fit,minmax(min(280px,100%),1fr))] gap-[1.2rem]">
    {services.map((service, i) => (
      <div class="reveal h-full" style={`transition-delay:${i * 80}ms`}>
        <ServiceCard {...service} />
      </div>
    ))}
  </div>
</section>
