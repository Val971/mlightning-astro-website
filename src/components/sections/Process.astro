---
import { processSteps } from '@/data/process';
---
<section id="process" class="border-t border-white/[.08] bg-white/[.02]">
  <div class="max-w-content mx-auto px-6 py-section">
    <div class="reveal max-w-[46ch] mb-12">
      <span class="holo-text uppercase tracking-[.14em] text-[.8rem] font-bold block">Le process</span>
      <h2 class="text-[clamp(2rem,4.4vw,3.4rem)] mt-[.9rem]">Simple, du premier appel à la livraison</h2>
    </div>

    <div class="grid grid-cols-[repeat(auto-fit,minmax(min(230px,100%),1fr))] gap-[1.2rem]">
      {processSteps.map((step, i) => (
        <div class="reveal h-full" style={`transition-delay:${i * 80}ms`}>
          <div class="h-full p-[1.8rem] border border-white/10 rounded-2xl bg-white/[.02]">
            <div class="holo-text font-heading font-extrabold text-[2.6rem]">{step.n}</div>
            <h3 class="text-[1.25rem] mt-[.7rem] mb-[.5rem]">{step.title}</h3>
            <p class="text-white/60 text-[.92rem] leading-[1.55]">{step.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
