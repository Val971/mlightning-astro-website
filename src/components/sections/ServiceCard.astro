---
import type { Service } from '@/data/services';

export type Props = Service;
const { num, label, desc, heroImage, slug } = Astro.props;
---
<a
  href={`/services/${slug}`}
  class="group glass-card h-full rounded-card p-[1.3rem] flex flex-col transition-transform duration-300 hover:-translate-y-[6px] hover:border-white/[.28]"
>
  <div class="relative aspect-[16/11] rounded-2xl overflow-hidden mb-[1.3rem] border border-white/[.08]">
    <img
      src={heroImage}
      alt={label}
      loading="lazy"
      class="no-drag absolute inset-0 w-full h-full object-cover"
    />
  </div>
  <span class="font-heading font-bold text-[.85rem] text-white/40">{num}</span>
  <h3 class="text-[1.5rem] mt-[.4rem] mb-[.6rem]">{label}</h3>
  <p class="text-white/[.62] text-[.95rem] leading-[1.55]">{desc}</p>
  <span class="mt-4 text-[.9rem] font-semibold text-white/80 group-hover:text-white inline-flex items-center gap-[.35rem]">
    En savoir plus →
  </span>
</a>
