---
import { phoneHref, phoneNumber } from '@/data/nav';
import { socials } from '@/data/socials';
import { address, openingHours, host } from '@/data/business';
import { services } from '@/data/services';
---
<footer class="border-t border-white/[.08]">
  <div class="max-w-content mx-auto px-6 pt-14 pb-8 grid grid-cols-[repeat(auto-fit,minmax(min(220px,100%),1fr))] gap-10">
    <div class="max-w-[34ch]">
      <img
        src="/images/logo-holo-cropped.webp"
        alt="Mlightning Custom"
        height="150"
        width="267"
        loading="lazy"
        class="mb-5 drop-shadow-[0_0_18px_rgba(183,166,255,.4)]"
      />
      <p class="text-white/[.55] leading-[1.6] text-[.92rem]">
        Personnalisation d'intérieurs automobiles haut de gamme. Confort, élégance et innovation dans chaque détail.
      </p>
    </div>

    <div>
      <h4 class="text-base mb-4 text-white">Services</h4>
      <div class="flex flex-col gap-[.6rem] text-[.92rem] text-white/60">
        {services.map((service) => (
          <a href={`/services/${service.slug}`} class="text-white/60 hover:text-white">{service.label}</a>
        ))}
      </div>
    </div>

    <div>
      <h4 class="text-base mb-4 text-white">Adresse</h4>
      <div class="flex items-start gap-[.55rem] text-[.92rem] text-white/60 leading-[1.6]">
        <span aria-hidden="true">📍</span>
        <span>
          {address.lines.map((line) => (<span class="block">{line}</span>))}
        </span>
      </div>

      <h4 class="text-base mb-4 mt-6 text-white">Nos horaires</h4>
      <p class="text-[.92rem] text-white/60 leading-[1.6]">
        {openingHours.label}<br />{openingHours.hours}
      </p>

      <p class="text-[.85rem] text-white/50 leading-[1.6] mt-4">
        ✈️ Déplacements ponctuels en Guadeloupe possibles, sur rendez-vous.
      </p>
    </div>

    <div>
      <h4 class="text-base mb-4 text-white">Contact</h4>
      <div class="flex flex-col gap-[.6rem] text-[.92rem] text-white/60">
        <a href={phoneHref} class="text-white/60 hover:text-white">{phoneNumber}</a>
        {socials.map((social) => (
          <a href={social.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-[.55rem] text-white/60 hover:text-white">
            <img src={social.icon} alt="" width="18" height="18" class="w-[18px] h-[18px] object-contain" />
            {social.name}
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="border-t border-white/[.08]">
    <div class="max-w-content mx-auto px-6 py-[1.4rem] flex flex-wrap justify-between gap-4 text-[.82rem] text-white/[.45]">
      <span>© 2026 Mlightning Custom. Tous droits réservés.</span>
      <span class="flex gap-2">
        <a href="/mentions-legales" class="hover:text-white/70 underline">Mentions légales</a>
        ·
        <a href="/politique-de-confidentialite" class="hover:text-white/70 underline">Confidentialité</a>
      </span>
      <span class="flex items-center gap-[.35rem]">
        Made with <span aria-hidden="true" class="text-[#ff5c7a]">❤</span> by
        <a href={host.website} target="_blank" rel="noopener noreferrer" class="hover:text-white/70 underline">{host.name}</a>
      </span>
    </div>
  </div>
</footer>
