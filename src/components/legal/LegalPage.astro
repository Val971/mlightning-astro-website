---
export type Props = { title: string; updatedAt: string };
const { title, updatedAt } = Astro.props;
---
<section class="max-w-content mx-auto px-6 pt-[clamp(3rem,6vw,5rem)] pb-[clamp(4rem,7vw,7rem)]">
  <a href="/" class="text-white/60 hover:text-white text-sm">← Retour à l'accueil</a>
  <h1 class="text-[clamp(2rem,4.4vw,3rem)] mt-6 mb-2 tracking-[-.01em]">{title}</h1>
  <p class="text-white/45 text-[.85rem] mb-10">Dernière mise à jour : {updatedAt}</p>
  <div class="flex flex-col gap-8 max-w-[72ch]"><slot /></div>
</section>
