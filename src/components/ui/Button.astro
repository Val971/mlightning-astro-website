---
export type Props = {
  href?: string;
  variant?: 'holo' | 'outline';
  class?: string;
  type?: 'button' | 'submit';
};

const { href, variant = 'holo', class: className = '', type } = Astro.props;
const cls = `${variant === 'holo' ? 'btn-holo' : 'btn-outline'} ${className}`;
---
{href ? (
  <a href={href} class={cls}><slot /></a>
) : (
  <button type={type ?? 'button'} class={cls}><slot /></button>
)}
