---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { services } from '@/data/services';
---
<BaseLayout title="Page introuvable" noindex={true} canonicalPath="/404">
  <section class="max-w-content mx-auto px-6 min-h-[70vh] flex flex-col items-center justify-center text-center py-[clamp(3rem,8vw,6rem)]">
    <span
      class="animate-fade-up inline-flex items-center gap-[.55rem] px-4 py-2 rounded-pill border border-white/[.16] bg-white/[.04] text-[.8rem] font-semibold uppercase tracking-[.06em] text-white/80"
      style="animation-delay: 0s;"
    >
      <span class="w-[7px] h-[7px] rounded-full bg-[#7dd3fc]" style="box-shadow: 0 0 10px #7dd3fc;"></span>
      Erreur 404
    </span>

    <h1
      class="animate-fade-up holo-text tracking-[-.02em] mt-6"
      style="animation-delay: .1s; font-size: clamp(5.5rem, 18vw, 10rem); line-height: 1;"
    >404</h1>

    <h2 class="animate-fade-up text-[clamp(1.5rem,3.2vw,2.2rem)] mt-4 max-w-[26ch]" style="animation-delay: .18s;">
      Cette route ne mène nulle part.
    </h2>

    <p class="animate-fade-up text-white/60 text-[clamp(1rem,1.4vw,1.15rem)] max-w-[46ch] mt-4 leading-[1.6]" style="animation-delay: .26s;">
      La page que vous cherchez a disparu, changé d'adresse, ou n'a jamais existé. On vous remet sur la bonne voie ?
    </p>

    <div class="animate-fade-up flex flex-wrap justify-center gap-[.9rem] mt-8" style="animation-delay: .34s;">
      <Button href="/">Retour à l'accueil</Button>
      <Button href="/#services" variant="outline">Voir nos services</Button>
    </div>

    <div class="animate-fade-up flex flex-wrap justify-center gap-x-2 gap-y-1 mt-9 text-[.85rem] text-white/45" style="animation-delay: .42s;">
      {services.map((service, i) => (
        <span>
          <a href={`/services/${service.slug}`} class="hover:text-white/80 underline">{service.label}</a>
          {i < services.length - 1 && <span class="mx-2">·</span>}
        </span>
      ))}
    </div>
  </section>
</BaseLayout>
